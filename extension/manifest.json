{
  "manifest_version": 3,
  "name": "TradingView Ticker Bridge",
  "version": "2.0.0",
  "key": "",
  "description": "Detect the active TradingView ticker and send it to the local desktop bridge.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["nativeMessaging"],
  "content_scripts": [
    {
      "matches": [
        "https://www.tradingview.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
